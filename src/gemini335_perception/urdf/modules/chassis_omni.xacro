<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="chassis_omni">
    <!-- Base Link -->
    <link name="base_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <cylinder radius="0.18" length="0.06"/>
        </geometry>
        <material name="chassis_color">
          <color rgba="0.74 0.90 0.95 1" />
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <cylinder radius="0.18" length="0.06"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="-0.0098 0 0.0213" rpy="0 0 0" />
        <mass value="1.057" />
        <inertia ixx="0.00507" ixy="-1.75e-06" ixz="7.54e-07" iyy="0.00482" iyz="6.26e-09" izz="0.00972" />
      </inertial>
    </link>

    <!-- Wheel Macro -->
    <xacro:macro name="omni_wheel" params="prefix origin_xyz origin_rpy">
      <link name="${prefix}_link">
        <visual>
          <origin xyz="0 0 0" rpy="1.5708 0 0"/>
          <geometry>
            <cylinder radius="0.0636" length="0.05"/>
          </geometry>
          <material name="wheel_color">
            <color rgba="0.37 0.37 0.37 1" />
          </material>
        </visual>
        <collision>
          <!-- Cylinder aligned along Y axis -->
          <origin xyz="0 0 0" rpy="1.5708 0 0"/>
          <geometry>
            <cylinder radius="0.0636" length="0.05"/>
          </geometry>
        </collision>
        <inertial>
          <origin xyz="0 0.031 0" rpy="0 0 0" />
          <mass value="0.0276" />
          <inertia ixx="5.37e-06" ixy="0" ixz="0" iyy="7.33e-06" iyz="0" izz="5.37e-06" />
        </inertial>
      </link>
      <joint name="${prefix}_joint" type="continuous">
        <origin xyz="${origin_xyz}" rpy="${origin_rpy}" />
        <parent link="base_link" />
        <child link="${prefix}_link" />
        <axis xyz="0 -1 0" />
      </joint>
    </xacro:macro>

    <xacro:omni_wheel prefix="quanxiang_wheel1" origin_xyz="0.18229 -0.00010361 -0.028" origin_rpy="0 0 1.5708" />
    <xacro:omni_wheel prefix="quanxiang_wheel2" origin_xyz="-0.090865 0.1576 -0.028" origin_rpy="0 0 -2.618" />
    <xacro:omni_wheel prefix="quanxiang_wheel3" origin_xyz="-0.090865 -0.15781 -0.028" origin_rpy="0 0 -0.5236" />

  </xacro:macro>
</robot>
