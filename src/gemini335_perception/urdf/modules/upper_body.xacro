<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="upper_body" params="parent_link">
    <!-- Main Frame / Torso -->
    <link name="torso_link">
      <visual>
        <origin xyz="-0.05 0 0.15" rpy="0 0 0"/>
        <geometry>
          <box size="0.2 0.25 0.25"/>
        </geometry>
        <material name="frame_color">
          <color rgba="0.6 0.6 0.6 1" />
        </material>
      </visual>
      <collision>
        <!-- Safe box approximation to cover the main structure -->
        <origin xyz="-0.05 0 0.15" rpy="0 0 0"/>
        <geometry>
          <box size="0.2 0.25 0.25"/>
        </geometry>
      </collision>
      <xacro:box_inertia m="5.0" x="0.2" y="0.25" z="0.25">
        <origin xyz="-0.05 0 0.15" rpy="0 0 0"/>
      </xacro:box_inertia>
    </link>
    <joint name="torso_joint" type="fixed">
      <parent link="${parent_link}"/>
      <child link="torso_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>
    
    <gazebo reference="torso_link">
      <material>Gazebo/Grey</material>
    </gazebo>

    <!-- Arm Base 1 (Left) -->
    <link name="arm_base_left_link">
      <visual>
        <geometry>
          <cylinder radius="0.04" length="0.02"/>
        </geometry>
        <material name="arm_color"><color rgba="0.2 0.2 0.2 1"/></material>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="0.04" length="0.02"/>
        </geometry>
      </collision>
      <xacro:cylinder_inertia m="1.0" r="0.04" h="0.02">
        <origin xyz="0 0 0" rpy="0 0 0"/>
      </xacro:cylinder_inertia>
    </link>
    <joint name="arm_base_left_joint" type="fixed">
      <parent link="torso_link"/>
      <child link="arm_base_left_link"/>
      <!-- Symmetrical circular holes on the frame, approximate pos -->
      <origin xyz="-0.1 0.1 0.25" rpy="0 0 0"/> 
    </joint>

    <gazebo reference="arm_base_left_link">
      <material>Gazebo/FlatBlack</material>
    </gazebo>

    <!-- Arm Base 2 (Right) -->
    <link name="arm_base_right_link">
      <visual>
        <geometry>
          <cylinder radius="0.04" length="0.02"/>
        </geometry>
        <material name="arm_color"><color rgba="0.2 0.2 0.2 1"/></material>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="0.04" length="0.02"/>
        </geometry>
      </collision>
      <xacro:cylinder_inertia m="1.0" r="0.04" h="0.02">
        <origin xyz="0 0 0" rpy="0 0 0"/>
      </xacro:cylinder_inertia>
    </link>
    <joint name="arm_base_right_joint" type="fixed">
      <parent link="torso_link"/>
      <child link="arm_base_right_link"/>
      <origin xyz="-0.1 -0.1 0.25" rpy="0 0 0"/> 
    </joint>

    <gazebo reference="arm_base_right_link">
      <material>Gazebo/FlatBlack</material>
    </gazebo>

  </xacro:macro>
</robot>
